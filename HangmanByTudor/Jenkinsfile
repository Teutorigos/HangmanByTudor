pipeline {
    agent {
        docker { 
            image 'mcr.microsoft.com/dotnet/sdk:9.0'
            // This line sets working folders and cache in an accessible area
            args '-u root -e DOTNET_CLI_HOME=/tmp -e DOTNET_NOLOGO=1'
        }
    }
    environment {
        // Setting the solution path
        SOLUTION_PATH = 'HangmanByTudor/HangmanByTudor.sln'
    }
    stages {
        stage('Build') { 
            steps {
                echo 'Compiling...'
                sh "dotnet build ${SOLUTION_PATH} --configuration Release"
            }
        }
        stage('Test') { 
            steps {
                echo 'Running automated tests...'
                sh "dotnet test ${SOLUTION_PATH} --configuration Release --no-build --logger 'junit;LogFilePath=test-results.xml'"            
            }
        }
        stage('Docker Build') { 
            steps {
                script {
                    // Build image using Dockerfile
                    dockerImage = docker.build("hangman-game:latest")
                }
            }
        }
    }
    post {
        always {
            // Archiving test results to see them in Jenkins UI
            junit '**/test-results.xml'
        }
        failure {
            echo 'Build or tests failed. Check logs!'
        }
    }
}