pipeline {
    agent any

    environment {
        // Setting the solution path
        SOLUTION_PATH = 'HangmanByTudor/HangmanByTudor.sln'
    }
    stages {
        stage('Build & Test') { 
            steps {
                echo 'Compiling...'
                sh 'export DOTNET_ROOT=/home/vboxuser/.dotnet; export PATH=$PATH:$DOTNET_ROOT:$DOTNET_ROOT/tools; dotnet build HangmanByTudor/HangmanByTudor.sln --configuration Release'                

                echo 'Running automated tests...'
                sh 'export DOTNET_ROOT=/home/vboxuser/.dotnet; export PATH=$PATH:$DOTNET_ROOT:$DOTNET_ROOT/tools; dotnet test HangmanByTudor/HangmanByTudor.sln --configuration Release --no-build --logger "junit;LogFilePath=test-results.xml"'            }
        }
        stage('Docker Build') { 
            steps {
                script {
                    // Build image using Dockerfile
                    echo 'Building Docker image...'
                    dockerImage = docker.build("hangman-game:latest")
                }
            }
        }
    }
    post {
        always {
            // Archiving test results to see them in Jenkins UI
            junit '**/test-results.xml'
        }
        failure {
            echo 'Build or tests failed. Check logs!'
        }
    }
}