pipeline {
    agent any

    environment {
        SOLUTION_PATH = 'HangmanByTudor/HangmanByTudor.sln'
        DOTNET_ROOT = '/opt/dotnet'
        PATH = "${env.PATH}:/opt/dotnet:/opt/dotnet/tools"
    }

    stages {
        stage('Build & Test') { 
            steps {
                echo 'Compiling...'
                sh "dotnet build ${SOLUTION_PATH} --configuration Release"
                echo 'Running automated tests...'
                sh "dotnet test ${SOLUTION_PATH} --configuration Release --no-build --logger 'junit;LogFilePath=test-results.xml'"
            }
        }
        
        stage('Docker Build') { 
            steps {
                script {
                    sh 'docker build -f HangmanByTudor/Dockerfile -t hangman-game:latest .'

                    echo 'Injecting build context into Minikube...'
                    // EVAL $(minikube docker-env) - Aceasta este comanda "fortata"
                    // Ea redirecteaza toate comenzile docker sa trimita imaginea direct in cluster
                    sh 'eval $(minikube docker-env) && docker build -f HangmanByTudor/Dockerfile -t hangman-game:latest .'
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                // Nu mai incarcam nimic, imaginea este deja "acasa"
                sh 'kubectl apply -f k8s-deployment.yaml'
                sh 'kubectl rollout restart deployment/hangman-deployment'
            }
        }
    }
    
    post {
        always {
            junit '**/test-results.xml'
        }
        failure {
            echo 'Build or tests failed. Check logs!'
        }
    }
}